# ==============================================================================
# BACKEND ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Server Configuration
NODE_ENV=development
PORT=5000

# ==============================================================================
# DATABASE - Supabase PostgreSQL
# ==============================================================================
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Get this from your Supabase project settings

# ==============================================================================
# GOOGLE OAuth 2.0 - Gmail API
# ==============================================================================
GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GMAIL_CLIENT_SECRET=your_oauth_client_secret
# Keep this secret and never expose it
GMAIL_REDIRECT_URI=http://localhost:5000/auth/callback
# In production, change to: https://yourdomain.com/auth/callback

# ==============================================================================
# AI MODELS
# ==============================================================================
# Google Gemini API (Required - Primary Model)
GEMINI_API_KEY=sk-...
# Get from: https://ai.google.dev/
# Use gemini-1.5-pro or gemini-1.5-flash for better context handling

# NVIDIA NIM API (Required - Secondary Model)
NVIDIA_NIM_API_KEY=nvapi-...
# Get from: https://build.nvidia.com/
# Used for email categorization and classification tasks

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
# Generate a random 32+ character string for JWT signing
# In production, use a strong random string

JWT_EXPIRY=7d
# Token expiry duration (7 days recommended)

# ==============================================================================
# API RATE LIMITING & QUOTAS
# ==============================================================================
GMAIL_RATE_LIMIT_PER_MINUTE=60
# Gmail API allows ~250 requests per user per second, but we limit to avoid quota issues

SYNC_BATCH_SIZE=100
# Number of emails to fetch in each Gmail API batch

MAX_PAGES_PER_SYNC=10
# Maximum pages to fetch during initial sync (100 emails per page)

# ==============================================================================
# VECTOR DATABASE / EMBEDDINGS
# ==============================================================================
# Using Supabase's pgvector extension
EMBEDDING_MODEL=text-embedding-3-small
# Model used for generating embeddings
# Options: text-embedding-3-small (1536 dims), text-embedding-3-large (3072 dims)

EMBEDDING_BATCH_SIZE=25
# Number of texts to embed at once

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================
LOG_LEVEL=info
# Options: debug, info, warn, error

# ==============================================================================
# OPTIONAL: Advanced Features
# ==============================================================================
ENABLE_NEWSLETTER_DEDUP=true
# Enable automatic newsletter deduplication

DEDUP_SIMILARITY_THRESHOLD=0.85
# Semantic similarity threshold for deduplication (0-1, higher = stricter)

CACHE_SUMMARIES=true
# Cache email summaries in Redis to avoid re-generating

CACHE_TTL_MINUTES=1440
# Cache time-to-live in minutes (1440 = 24 hours)

# ==============================================================================
# OPTIONAL: Email Sync Configuration
# ==============================================================================
INITIAL_SYNC_DAYS=30
# How many days back to sync on first connection (30 days recommended)

INCREMENTAL_SYNC_INTERVAL_MINUTES=5
# How often to check for new emails (5 minutes recommended)

# ==============================================================================
# OPTIONAL: Debugging
# ==============================================================================
DEBUG_GMAIL_API=false
# Log all Gmail API requests/responses (verbose, use for debugging only)

DEBUG_EMBEDDINGS=false
# Log embedding generation (verbose)

DEBUG_RAG=false
# Log RAG pipeline decisions

# ==============================================================================
# END OF BACKEND ENVIRONMENT VARIABLES
# ==============================================================================
